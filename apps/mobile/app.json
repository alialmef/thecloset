{
  "expo": {
    "name": "Closet",
    "slug": "closet",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.closet.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "package": "app.closet.mobile"
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker"
    ]
  }
}

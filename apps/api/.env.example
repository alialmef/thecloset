# ─── Database ─────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/closet_dev"

# ─── Server ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Auth ────────────────────────────────────────────
JWT_SECRET=change-me-to-a-real-secret
JWT_EXPIRES_IN=7d

# ─── AWS S3 / Cloudflare R2 (Image Storage) ──────────
S3_BUCKET=closet-images
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_ENDPOINT=  # Leave empty for AWS S3, set for R2/MinIO

# ─── AI Vision API ───────────────────────────────────
VISION_API_KEY=your-vision-api-key
VISION_API_PROVIDER=openai  # openai | anthropic

# ─── Delivery APIs ───────────────────────────────────
UBER_DIRECT_CLIENT_ID=
UBER_DIRECT_CLIENT_SECRET=
DOORDASH_DEVELOPER_ID=
DOORDASH_KEY_ID=
DOORDASH_SIGNING_SECRET=

# ─── Firebase (Push Notifications) ───────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
